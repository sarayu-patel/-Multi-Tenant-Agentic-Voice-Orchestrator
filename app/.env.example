# MongoDB - use Atlas free tier M0
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/?retryWrites=true&w=majority
MONGODB_DB_NAME=voice_agent
# Vapi - get these from app.vapi.ai dashboard
VAPI_API_KEY=your_vapi_private_key_here
VAPI_PHONE_NUMBER_ID=your_vapi_phone_number_id_here

# OpenAI - used by LangGraph to evaluate call transcripts (primary)
OPENAI_API_KEY=your_openai_key_here

# Google Gemini - used as the fallback evaluator if OpenAI fails
GOOGLE_API_KEY=your_google_ai_key_here
